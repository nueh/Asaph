# Block direct access to SQLite databases, PHP class files, and data files
# in case they end up inside the web root.
<FilesMatch "\.(db|sqlite|sqlite3)$">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order deny,allow
		Deny from all
	</IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
	# Add 'rw' parameter, so we can detect whether mod_rewrite is enabled
	RewriteEngine on
	RewriteRule ^$ index.php?rw

	# Rewrite everything to index.php if it is not a real file or directory
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteRule ^(.*)$ index.php?rw=$1
</IfModule>